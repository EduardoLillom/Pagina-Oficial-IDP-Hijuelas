---
import BaseLayout from '../layouts/BaseLayout.astro';

// Datos de los hitos: Puedes editarlos fácilmente aquí
const hitos = [
  { fecha: "Marzo 2026", titulo: "Compra del terreno", desc: "Se concretó la adquisición del espacio para nuestra nueva casa." },
  { fecha: "Mayo 2026", titulo: "Inicio de cimientos", desc: "Comenzamos con la preparación del terreno y estructuras base." },
  { fecha: "Agosto 2026", titulo: "Estructura metálica", desc: "Levantamiento del esqueleto principal del edificio." }
];
---

<BaseLayout pageTitle="Nuestro Nuevo Templo">
  <div class="bg-slate-50 min-h-screen pt-28 py-20">
    <div class="max-w-4xl mx-auto px-4">
      
      <div class="text-center mb-20">
        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 mb-6">Construyendo nuestra casa</h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Un espacio diseñado para adorar, aprender y servir a nuestra comunidad en Hijuelas.</p>
      </div>

      <section class="mb-20 bg-white p-10 rounded-3xl border border-slate-100 shadow-sm">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-6">Nuestra Historia</h2>
            <p class="text-slate-600 leading-relaxed mb-4">
              Desde nuestros inicios en Hijuelas, nuestra comunidad ha crecido no solo en número, sino en fe y servicio. Tras años de reuniones en espacios temporales, Dios abrió la puerta para obtener nuestro terreno propio.
            </p>
            <p class="text-slate-600 leading-relaxed">
              Este templo no es solo un edificio; es el cumplimiento de una visión de décadas. Necesitamos un espacio permanente que nos permita acoger a más familias y albergar nuestros programas de ayuda social.
            </p>
          </div>
          <div class="bg-slate-200 h-64 rounded-2xl flex items-center justify-center text-slate-400">
            [Espacio para foto del diseño del templo]
          </div>
        </div>
      </section>

      <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-200 mb-16">
        <div class="flex justify-between mb-2">
          <span class="font-bold text-slate-900">Progreso de obra</span>
          <span class="text-cyan-600 font-bold">45%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-4">
          <div class="bg-cyan-600 h-4 rounded-full" style="width: 45%"></div>
        </div>
      </div>

      <div class="relative border-l-2 border-slate-200 ml-3 space-y-12 mb-20">
        {hitos.map((hito) => (
          <div class="relative pl-8">
            <div class="absolute -left-[9px] top-1 w-4 h-4 bg-cyan-600 rounded-full"></div>
            <span class="text-sm font-bold text-cyan-600 uppercase tracking-widest">{hito.fecha}</span>
            <h3 class="text-xl font-bold text-slate-900 mt-1">{hito.titulo}</h3>
            <p class="text-slate-600 mt-2">{hito.desc}</p>
          </div>
        ))}
      </div>

    <!-- <div class="text-center bg-slate-900 p-12 rounded-3xl text-white shadow-xl">
        <h2 class="text-3xl font-bold mb-4">¿Quieres ser parte?</h2>
        <p class="text-slate-300 mb-8 max-w-md mx-auto">Cada oración y cada aporte cuenta para ver esta visión hecha realidad.</p>
        <a href="/donar" class="bg-cyan-600 px-8 py-4 rounded-full font-bold hover:bg-cyan-500 transition shadow-lg">Conocer cómo ayudar</a>
    </div> -->

    </div>
  </div>
</BaseLayout>