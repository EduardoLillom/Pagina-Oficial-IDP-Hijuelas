---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getActivePosts } from '../../../lib/posts';

const featuredItems = await getActivePosts();
---

<AdminLayout title="Contenido Destacado">
  <div class="mx-auto max-w-4xl">
    <!-- Action Bar: Aquí es donde vive la lógica de 'Crear' -->
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Contenido Destacado</h1>
        <p class="text-sm text-slate-500">Arrastra para reordenar la prioridad.</p>
      </div>
      <a href="/admin/contenido-destacado/nuevo" 
         class="bg-cyan-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-cyan-700 shadow-sm transition-all flex items-center gap-2">
        <span>+</span> Nuevo
      </a>
    </div>

    <!-- Lista -->
    <ul id="sortable-list" class="flex flex-col gap-3">
      {featuredItems.map((item) => (
        <li data-id={item.id} class="group flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-cyan-200 transition-all">
          <div class="cursor-grab text-slate-300 hover:text-cyan-600 p-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path></svg>
          </div>
          <div class="flex-1">
            <h4 class="font-semibold text-slate-900">{item.title}</h4>
            <p class="text-xs text-slate-500">{item.summary || item.type}</p>
          </div>
          <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <a href={`/admin/contenido-destacado/editar/${item.id}`} class="px-3 py-1.5 text-xs text-slate-600 hover:text-cyan-600">Editar</a>
            <button onclick={`handleDelete('${item.id}')`} class="px-3 py-1.5 text-xs font-medium text-red-500 hover:text-red-700">Eliminar</button>
          </div>
        </li>
      ))}
    </ul>
  </div>
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js" is:inline></script>
<script is:inline>
  new Sortable(document.getElementById('sortable-list'), {
    handle: '.cursor-grab',
    animation: 150,
    onEnd: (evt) => { console.log("Orden actualizado"); }
  });

  function handleDelete(id) {
    if (confirm("¿Estás seguro de eliminar este contenido?")) {
      console.log("Eliminando:", id);
      // Aquí tu lógica de fetch para borrar
    }
  }
</script>