---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Crear Publicación">
  <section class="mx-auto max-w-4xl px-4 py-10">
    <div class="mb-8 flex items-center gap-4">
      <a href="/admin/contenido-destacado" class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition hover:border-cyan-600 hover:text-cyan-600">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">Crear publicación</h1>
        <p class="text-sm text-slate-500">Configura el contenido para el carrusel principal.</p>
      </div>
    </div>

    <form action="/api/admin/post" method="POST" class="space-y-6">
      <input type="hidden" name="_action" value="create" />
      
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-700">Tipo de contenido</label>
            <select id="type-selector" name="type" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition">
              <option value="noticia">Noticia</option>
              <option value="evento">Evento</option>
              <option value="aviso">Aviso</option>
              <option value="cita">Cita / Frase</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700">Fecha de publicación</label>
            <input name="publish_date" type="datetime-local" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition" />
          </div>

          <div class="sm:col-span-2">
            <label id="label-title" class="block text-sm font-semibold text-slate-700">Título *</label>
            <input id="input-title" name="title" type="text" required placeholder="Título principal..." class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition" />
          </div>
        </div>
      </div>

      <div id="section-summary" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <label id="label-summary" class="block text-sm font-semibold text-slate-700">Resumen</label>
        <textarea id="input-summary" name="summary" rows="3" placeholder="Descripción breve..." class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition"></textarea>
      </div>

      <div id="group-content" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <label class="block text-sm font-semibold text-slate-700">Contenido Detallado</label>
        <textarea name="content" rows="4" placeholder="Detalles extendidos..." class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition"></textarea>
      </div>

      <div class="flex items-center justify-end gap-4 p-4">
        <a href="/admin/contenido-destacado" class="text-sm font-semibold text-slate-600 hover:text-slate-900">Cancelar</a>
        <button type="submit" class="rounded-full bg-cyan-600 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-cyan-600/20 hover:bg-cyan-500 transition">
          Guardar Publicación
        </button>
      </div>
    </form>
  </section>
</AdminLayout>

<script>
  function setupForm() {
    const selector = document.getElementById('type-selector') as HTMLSelectElement;
    const groupContent = document.getElementById('group-content');
    const sectionSummary = document.getElementById('section-summary');
    const labelTitle = document.getElementById('label-title');
    const labelSummary = document.getElementById('label-summary');
    const inputTitle = document.getElementById('input-title') as HTMLInputElement;
    const inputSummary = document.getElementById('input-summary') as HTMLTextAreaElement;

    selector.addEventListener('change', () => {
      const type = selector.value;
      
      groupContent?.classList.remove('hidden');
      sectionSummary?.classList.remove('hidden');

      if (type === 'cita') {
        labelTitle!.innerText = "Cita Completa (con autor) *";
        inputTitle.placeholder = "Ej: \"La fe es dar el primer paso...\" — Martin Luther King";
        sectionSummary?.classList.add('hidden');
        groupContent?.classList.add('hidden');
      } else if (type === 'aviso') {
        labelTitle!.innerText = "Título del Aviso *";
        labelSummary!.innerText = "Mensaje breve";
        groupContent?.classList.add('hidden');
      } else if (type === 'evento') {
        labelTitle!.innerText = "Nombre del Evento *";
        labelSummary!.innerText = "Breve descripción";
      } else {
        labelTitle!.innerText = "Título de la Noticia *";
        labelSummary!.innerText = "Resumen / Extracto";
      }
    });
  }
  setupForm();
</script>