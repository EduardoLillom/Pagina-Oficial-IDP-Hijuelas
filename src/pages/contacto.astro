---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Contacto">
  <section class="relative min-h-screen bg-slate-50 py-20 pt-32 overflow-hidden">
    <!-- Fondo decorativo -->
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-cyan-100 rounded-full blur-3xl opacity-50"></div>
    
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6">
      
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-cyan-600 font-bold tracking-widest uppercase text-sm">Contacto</span>
        <h1 class="mt-3 text-5xl font-extrabold text-slate-900 tracking-tight">Estamos aquí para ti</h1>
        <p class="mt-6 text-lg text-slate-600">
          Ya sea que necesites información, apoyo o quieras ser parte de nuestra comunidad en Hijuelas, estos son nuestros canales oficiales.
        </p>
      </div>

      <!-- Grid de tarjetas -->
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        
        <!-- Tarjeta: Dirección -->
        <div class="bg-white/70 backdrop-blur-lg border border-white/50 p-8 rounded-[2rem] shadow-xl shadow-slate-200/50">
          <div class="text-cyan-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Nuestro lugar de reunión</h3>
          <p class="mt-2 text-lg font-semibold text-slate-900">Sede Villa Los Naranjos</p>
          <span class="inline-block mt-2 px-3 py-1 bg-amber-100 text-amber-700 text-[10px] font-bold uppercase rounded-full">
            Ubicación temporal
          </span>
        </div>

        <!-- Tarjeta: Correo -->
        <div class="bg-white/70 backdrop-blur-lg border border-white/50 p-8 rounded-[2rem] shadow-xl shadow-slate-200/50">
          <div class="text-cyan-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Escríbenos</h3>
          <p class="mt-2 text-lg font-semibold text-slate-900">idphijuelas2026@gmail.com</p>
        </div>

        <!-- Tarjeta: Redes Sociales -->
        <div class="bg-white/70 backdrop-blur-lg border border-white/50 p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 flex flex-col justify-between">
          <!-- Icono de redes sociales (Share/Connect) -->
          <div class="text-cyan-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
          </div>
          
          <div>
            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Comunidad</h3>
            <div class="mt-4 flex gap-4">
              <a href="https://www.instagram.com/idphijuelas/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-slate-900 text-white rounded-full text-sm font-medium hover:bg-cyan-600 transition-colors">Instagram</a>
              <a href="https://www.facebook.com/idphijuelas/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-slate-900 text-white rounded-full text-sm font-medium hover:bg-cyan-600 transition-colors">Facebook</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>