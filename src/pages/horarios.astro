---
import BaseLayout from '../layouts/BaseLayout.astro';

const horarios = [
  { 
    day: "Jueves", 
    time: "19:30", 
    event: "Estudio Bíblico", 
    location: "Sede villa los naranjos",
    gradient: "from-sky-100 to-sky-50" 
  },
  { 
    day: "Viernes", 
    time: "19:30", 
    event: "Reunión de Jóvenes", 
    location: "Sede villa los naranjos",
    gradient: "from-blue-100 to-blue-50" 
  },
  { 
    day: "Viernes", 
    time: "19:30", 
    event: "Reunión de Damas", 
    location: "Pasaje el Rauli poblacion Sven krarup casa 940",
    gradient: "from-blue-100 to-blue-50" 
  },
  { 
    day: "Viernes", 
    time: "20:00", 
    event: "Reunión de Varones", 
    location: "Hogar hnm. Jaime Reinoso",
    gradient: "from-blue-100 to-blue-50" 
  },
  { 
    day: "Domingo", 
    time: "10:30", 
    event: "Reunión General", 
    location: "Salón Principal",
    gradient: "from-cyan-100 to-cyan-50" 
  },

];
---

<BaseLayout pageTitle="Horarios">
  <section class="bg-slate-50 py-20 pt-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      
      <div class="text-center mb-16">
        <span class="text-cyan-600 font-bold tracking-widest uppercase text-sm">Nuestros encuentros</span>
        <h1 class="mt-3 text-4xl font-extrabold text-slate-900">Horarios de Reuniones</h1>
      </div>

      <div class="space-y-6">
        {horarios.map((item) => (
          <div class={`group p-6 rounded-2xl border border-white/50 shadow-sm flex items-center justify-between hover:shadow-lg transition-all duration-300 bg-liner-to-r ${item.gradient}`}>
            
            <div class="flex items-center gap-6">
              <div class="text-center min-w-20 bg-white/50 p-2 rounded-xl backdrop-blur-sm">
                <span class="block text-2xl font-bold text-slate-900">{item.day.slice(0,3)}</span>
                <span class="text-xs uppercase text-slate-700 font-bold">{item.day}</span>
              </div>
              
              <div>
                <h3 class="text-xl font-bold text-slate-900">{item.event}</h3>
                <p class="text-slate-700/80 text-sm font-medium">Ubicación: {item.location}</p>
              </div>
            </div>

            <div class="bg-white/70 border border-white/50 px-4 py-2 rounded-lg shadow-sm backdrop-blur-sm">
              <span class="text-slate-900 font-bold font-mono">{item.time}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 p-8 bg-slate-900 rounded-3xl text-center text-white">
        <h3 class="text-xl font-bold mb-2">¿Es tu primera vez?</h3>
        <p class="text-slate-300">Te recibiremos con los brazos abiertos. No necesitas invitación, solo ven con ganas de compartir.</p>
      </div>

    </div>
  </section>
</BaseLayout>