---
import BaseLayout from '../layouts/BaseLayout.astro';
import AccordionCard from '../components/AccordionCard.astro';
import { doctrinas } from '../consts/doctrinas';
export const prerender = true;

const categories = [...new Set(doctrinas.map(d => d.category))];
---

<BaseLayout 
  pageTitle="Doctrinas"
  description="Explora los fundamentos de nuestra fe en la Iglesia de Dios de la Profecía. Principios bíblicos organizados para el estudio, la reflexión y la edificación espiritual."
  >
  <div class="bg-slate-50 min-h-screen pt-32 pb-20">
    <div class="max-w-5xl mx-auto px-4">
      
      <header class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Nuestras Doctrinas</h1>
        <p class="text-slate-600 max-w-lg mx-auto">Principios fundamentales de nuestra fe, organizados para tu estudio y edificación.</p>
      </header>

      <!-- Se añadió la clase 'scrollbar-hide' para ocultar la barra visualmente -->
      <nav class="flex flex-nowrap md:flex-wrap gap-2 mb-16 justify-start md:justify-center overflow-x-auto md:overflow-visible sticky top-24 z-20 bg-slate-50/80 backdrop-blur-md py-4 px-4 -mx-4 md:mx-0 md:px-0 scrollbar-hide">
        {categories.map(cat => (
          <a href={`#${cat.replace(/\s+/g, '-').toLowerCase()}`} 
             class="whitespace-nowrap px-5 py-2.5 bg-white border border-slate-200 rounded-full text-sm font-semibold text-slate-700 hover:border-cyan-500 hover:text-cyan-700 transition-all shadow-sm">
            {cat}
          </a>
        ))}
      </nav>

      <div class="space-y-16">
        {categories.map(cat => (
          <section id={cat.replace(/\s+/g, '-').toLowerCase()} class="scroll-mt-45 md:scroll-mt-55">
            <h2 class="text-2xl font-bold text-slate-900 mb-8 flex items-center gap-3">
               <span class="h-6 w-1.5 bg-cyan-600 rounded-full"></span>
               {cat}
            </h2>
            <div class="space-y-4">
              {doctrinas.filter(d => d.category === cat).map(item => (
                <AccordionCard 
                  title={`${item.id}. ${item.title}`} 
                  text={item.text} 
                />                
              ))}
            </div>
          </section>
        ))}
      </div>
      
    </div>
  </div>
</BaseLayout>

<style>
  /* Clase para ocultar la barra de scroll */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE y Edge */
    scrollbar-width: none;    /* Firefox */
  }

  html {
    scroll-behavior: smooth;
  }
</style>