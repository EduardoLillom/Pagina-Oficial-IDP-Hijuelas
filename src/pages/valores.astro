---
import BaseLayout from "../layouts/BaseLayout.astro";
// Incluye aquí tu descripción larga
const valores = [
  { title: "La Oración", text: "800 caracteres de texto aquí...", icon: "🙏" },
  // ... resto de los items
];
---

<BaseLayout pageTitle="valores">
<section class="py-20 bg-slate-50">
  <div class="max-w-3xl mx-auto px-4"> <!-- Max-w-3xl es mejor para lectura de textos largos -->
    <h2 class="text-3xl font-bold text-center text-slate-900 mb-12">Nuestros Valores</h2>
    
    <div class="space-y-4">
      {valores.map((item) => (
        <details class="group bg-white border border-slate-200 rounded-2xl p-6 transition-all duration-300 hover:border-cyan-200">
          <summary class="flex justify-between items-center font-medium cursor-pointer list-none text-lg text-slate-900">
            <div class="flex items-center gap-4">
              <span class="text-2xl">{item.icon}</span>
              {item.title}
            </div>
            <!-- Icono que gira al abrir -->
            <span class="transition group-open:rotate-45 text-2xl text-cyan-600">+</span>
          </summary>
          <div class="mt-4 pt-4 border-t border-slate-100 text-slate-600 leading-relaxed text-base">
            {item.text}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
</BaseLayout>

<style>
  /* Oculta la flecha por defecto de summary en algunos navegadores */
  summary::-webkit-details-marker {
    display: none;
  }
</style>