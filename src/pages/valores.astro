---
import BaseLayout from "../layouts/BaseLayout.astro";
import { valores } from "../consts/valores.ts";
---

<BaseLayout pageTitle="Nuestros Valores">
  <section class="py-20 bg-slate-50">
    <div class="max-w-5xl min-h-screen pt-32 mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-slate-900 mb-6">Nuestros Valores Centrales</h2>
      
      <!-- Texto introductorio -->
      <p class="max-w-2xl mx-auto text-center text-slate-600 mb-12 text-lg">
        Nuestra misión fluye directamente de nuestros valores centrales y los afirma en sus llamados. 
        Los valores centrales de la Iglesia de Dios de la Profecía son:
      </p>
      
      <div class="space-y-4">
        {valores.map((item) => (
          <details class="group bg-white border border-slate-200 rounded-2xl p-6 transition-all duration-300 hover:border-cyan-200">
            <summary class="flex justify-between items-center font-medium cursor-pointer list-none text-lg text-slate-900">
              <div class="flex items-center gap-4">
                <span class="text-2xl">{item.icon}</span>
                {item.title}
              </div>
              <span class="transition group-open:rotate-45 text-2xl text-cyan-600">+</span>
            </summary>
            <div class="mt-4 pt-4 border-t border-slate-100 text-slate-600 leading-relaxed text-base">
              {item.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>