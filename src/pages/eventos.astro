---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEventos } from '../lib/eventos';

// Usamos tu función centralizada
let eventos = [];
try {
  eventos = await getEventos() || [];
} catch (error) {
  console.error("Error al obtener eventos:", error);
}
---

<BaseLayout 
  pageTitle="Eventos"
  description="Mantente al día con todas las actividades y eventos de la Iglesia de Dios de la Profecía en Hijuelas. ¡Participa con nosotros en nuestros próximos encuentros!"  
>

  <div class="bg-slate-50 min-h-screen pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-4">
      
      <header class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Nuestros Eventos</h1>
        <p class="text-slate-600 max-w-lg mx-auto">Únete a nuestras próximas actividades y sé parte de nuestra comunidad.</p>
      </header>

      <div class="space-y-6">
        {eventos.length > 0 ? (
          eventos.map(evento => (
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col md:flex-row gap-6 items-center">
              
              <div class="flex flex-col items-center justify-center bg-cyan-50 rounded-2xl p-4 min-w-[80px] w-[80px] shrink-0 border border-cyan-100">
                <span class="text-cyan-700 font-bold text-2xl">{new Date(evento.fecha).getDate()}</span>
                <span class="text-cyan-600 font-bold uppercase text-xs tracking-wider">
                  {new Date(evento.fecha).toLocaleString('es-ES', { month: 'short' })}
                </span>
              </div>

              <div class="flex-1 text-center md:text-left">
                <h3 class="text-xl font-bold text-slate-900 mb-2">{evento.title}</h3>
                <p class="text-slate-600 text-sm mb-4 leading-relaxed">{evento.descripcion}</p>
                
                <div class="flex flex-wrap justify-center md:justify-start gap-4 text-sm text-slate-500">
                  <span class="flex items-center gap-1">🕒 {evento.hora.substring(0, 5)}</span>
                </div>
              </div>
            </div>
          ))
        ) : (
          <div class="text-center py-20 bg-white rounded-3xl border border-slate-200 border-dashed">
            <h3 class="text-xl font-bold text-slate-900 mb-2">Sin eventos programados</h3>
            <p class="text-slate-500">Por el momento no tenemos actividades públicas. ¡Vuelve pronto!</p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>