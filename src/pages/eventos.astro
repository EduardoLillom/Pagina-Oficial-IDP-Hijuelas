---
import BaseLayout from '../layouts/BaseLayout.astro';

// Datos de prueba
const eventos = [
  {
    id: 1,
    title: "Culto de Adoración Especial",
    date: "2026-06-25",
    time: "19:00",
    location: "Templo Central",
    description: "Una noche dedicada a la alabanza y ministración de la Palabra de Dios.",
    link: "#"
  },
  {
    id: 2,
    title: "Seminario de Jóvenes",
    date: "2026-07-10",
    time: "10:00",
    location: "Salón Multiuso",
    description: "Espacio de aprendizaje y comunión enfocado en los desafíos actuales de la juventud.",
    link: "#"
  },
  {
    id: 3,
    title: "Escuela de Formación Bíblica",
    date: "2026-07-15",
    time: "18:30",
    location: "Aula 2",
    description: "Continuamos con nuestro ciclo de estudio profundo sobre las epístolas paulinas.",
    link: "#"
  },
   {
    id: 4,
    title: "Escuela de Formación Bíblica",
    date: "2026-07-15",
    time: "18:30",
    location: "Aula 2",
    description: "Continuamos con nuestro ciclo de estudio profundo sobre las epístolas paulinas.",
    link: "#"
  },
    {
    id: 5,
    title: "Escuela de Formación Bíblica",
    date: "2026-07-15",
    time: "18:30",
    location: "Aula 2",
    description: "Continuamos con nuestro ciclo de estudio profundo sobre las epístolas paulinas.",
    link: "#"
  }
  
];

const proximosEventos = eventos.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
---

<BaseLayout pageTitle="Eventos">
  <div class="bg-slate-50 min-h-screen pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-4">
      
      <header class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Nuestros Eventos</h1>
        <p class="text-slate-600 max-w-lg mx-auto">Únete a nuestras próximas actividades y sé parte de nuestra comunidad.</p>
      </header>

      <div class="space-y-6">
        {proximosEventos.length > 0 ? (
          proximosEventos.map(evento => (
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col md:flex-row gap-6 items-center">
              
              <!-- Fecha destacada -->
              <div class="flex flex-col items-center justify-center bg-cyan-50 rounded-2xl p-4 min-w-[80px] w-[80px] shrink-0 border border-cyan-100">
                <span class="text-cyan-700 font-bold text-2xl">{new Date(evento.date).getDate()}</span>
                <span class="text-cyan-600 font-bold uppercase text-xs tracking-wider">
                  {new Date(evento.date).toLocaleString('es-ES', { month: 'short' })}
                </span>
              </div>

              <!-- Contenido -->
              <div class="flex-1 text-center md:text-left">
                <h3 class="text-xl font-bold text-slate-900 mb-2">{evento.title}</h3>
                <p class="text-slate-600 text-sm mb-4 leading-relaxed">{evento.description}</p>
                
                <div class="flex flex-wrap justify-center md:justify-start gap-4 text-sm text-slate-500">
                  <span class="flex items-center gap-1">📍 {evento.location}</span>
                  <span class="flex items-center gap-1">🕒 {evento.time}</span>
                </div>
              </div>

              <!-- Botón -->
              <div class="flex items-center w-full md:w-auto">
                <a href={evento.link} class="w-full text-center px-6 py-3 bg-slate-900 text-white rounded-full font-semibold hover:bg-cyan-700 transition-colors shadow-lg shadow-slate-200">
                  Ver detalle
                </a>
              </div>
            </div>
          ))
        ) : (
          <div class="text-center py-20">
            <p class="text-slate-500">No hay eventos próximos por el momento. ¡Vuelve pronto!</p>
          </div>
        )}
      </div>
      
    </div>
  </div>
</BaseLayout>