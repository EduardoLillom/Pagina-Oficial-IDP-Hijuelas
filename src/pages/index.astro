---
// src/pages/index.astro
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedCarousel from '../components/FeaturedCarousel.astro';
import Carousel from '../components/Carousel.astro';
import { services } from '../consts/services.js';
import { getActivePosts, type Slide } from '../lib/posts';

import JovenImage from '../assets/joven.webp'
import bibliaImage from '../assets/biblia.webp'
import alabanzaBautizoImage from '../assets/alabanzaBautizo.webp'

import bautizoImage from '../assets/bautizo.webp'
import iconoOracion from '../assets/icono-oracion.webp'
import iconoAdoracion from '../assets/icono-adoracion.webp'
import iconoServicio from '../assets/icono-servicio.webp'

const images = [
  { src: JovenImage, pos: 'object-center', alt: 'Joven en adoración' },
  { src: bibliaImage, pos: 'object-center', alt: 'Biblia abierta' },
  { src: alabanzaBautizoImage, pos: 'object-[10%_center]', alt: 'Alabanza en bautizo' },
];
const posts = await getActivePosts();

const slides: Slide[] = posts.map(post => ({
  title: post.title,
  summary: post.summary || (post.content ? `${post.content.substring(0, 100)}...` : ''),
  type: post.type,
  target_url: post.target_url || '#',
}));

---

<BaseLayout pageTitle="Inicio">
  <Hero />
  <FeaturedCarousel slides={ slides }/>
<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="text-center">
      <!-- Aquí reemplazamos la etiqueta Image original por tu nuevo componente genérico -->
      <Carousel 
        images={images} 
        className="h-96 w-full rounded-3xl object-right" 
      />
    </div>
    
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <div
          class={`rounded-3xl border bg-slate-50 p-8 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl ${service.accent || 'border-cyan-500'}`}
        >
          <h3 class="text-2xl font-bold text-slate-900 mb-3">{service.title}</h3>
          <p class="text-sm uppercase tracking-[0.28em] text-cyan-500 mb-4">{service.time}</p>
          <p class="text-slate-600 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

  <section class="bg-slate-950 py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <p class="text-sm uppercase tracking-[0.28em] text-cyan-300 font-semibold">Vida comunitaria</p>
          <h2 class="mt-4 text-3xl font-bold sm:text-4xl">Un espacio de amor y servicio</h2>
          <p class="mt-6 text-slate-300 leading-relaxed">
            Descubre cómo nuestras reuniones, ministerios y espacios de oración invitan a cada persona a vivir una fe auténtica y una comunidad cercana.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="/nosotros"
              class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400"
            >
              Conoce más
            </a>
            <a
              href="/contacto"
              class="inline-flex items-center justify-center rounded-full border border-slate-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
            >
              Contáctanos
            </a>
          </div>
        </div>

        <div class="overflow-hidden relative rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={ bautizoImage }
            alt="Encuentro de hermanos en adoración"
            class="h-96 w-full object-cover object-right"
          />
          <div class="absolute inset-0 bg-cyan-950/10 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-100 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 text-center">
      <p class="text-sm uppercase tracking-[0.28em] text-cyan-500 font-semibold">Nuestras prioridades</p>
      <h2 class="mt-4 text-3xl font-bold text-slate-900 sm:text-4xl">Fe, servicio y comunidad</h2>
      <p class="mx-auto mt-5 max-w-2xl text-slate-600 leading-relaxed">
        En cada actividad buscamos impactar vidas con la Palabra, la oración y un llamado a la unidad.
      </p>

      <div class="mt-16 grid gap-6 md:grid-cols-3">
        <div class="rounded-3xl bg-white p-8 shadow-lg text-center">
          <div class="mb-4 flex justify-center text-indigo-600">
            <Image src={ iconoAdoracion } alt="Adoración" class="w-32 h-32 object-contain">
          </div>
          <h3 class="text-2xl font-semibold text-slate-900 mb-3">Adoración</h3>
        </div>
        <div class="rounded-3xl bg-white p-8 shadow-lg text-center">
          <div class="mb-4 flex justify-center text-indigo-600">
            <Image src={ iconoOracion } alt="Oracion" class="w-32 h-32 object-contain">
          </div>
          <h3 class="text-2xl font-semibold text-slate-900 mb-3">Oracion</h3>
        </div>
        <div class="rounded-3xl bg-white p-8 shadow-lg text-center">
          <div class="mb-4 flex justify-center text-indigo-600">
            <Image src={ iconoServicio } alt="Servicio" class="w-32 h-32 object-contain">
          </div>
          <h3 class="text-2xl font-semibold text-slate-900 mb-3">Servicio</h3>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>