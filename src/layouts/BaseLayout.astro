---
// src/layouts/BaseLayout.astro
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactWidget from '../components/ContactWidget.astro';
import '../styles/global.css';

interface Props {
  pageTitle: string;
  description?: string;
  image?: string;
}

const { pageTitle, description = "Comunidad de fe y servicio en Hijuelas.", image = "/og-image.webp" } = Astro.props;

const canonicalURL = Astro.site 
  ? new URL(Astro.url.pathname, Astro.site) 
  : Astro.url.href;

// Función auxiliar para construir imágenes de forma segura
const getFullImageUrl = (img: string) => {
  return Astro.site ? new URL(img, Astro.site).toString() : img;
};

---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Básico -->
    <title>{pageTitle} | IDP Hijuelas</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:title" content={`${pageTitle} | IDP Hijuelas`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={getFullImageUrl(image)} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${pageTitle} | IDP Hijuelas`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={getFullImageUrl(image)} />
  </head>
  
  <body>
    <div class="min-h-screen flex flex-col w-full m-0 p-0">
      <Navbar />
      
      <main class="flex-1 w-full">
        <slot /> 
      </main>
      
      <Footer />
    </div>

    <ContactWidget />
  </body>
</html>