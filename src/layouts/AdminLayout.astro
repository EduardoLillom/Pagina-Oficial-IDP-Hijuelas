---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
import '../styles/global.css';

const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/contenido-destacado', label: 'Contenido destacado' },
  { href: '/admin/eventos', label: 'Eventos' },
];

const isActive = (path: string) => currentPath.startsWith(path) 
  ? 'bg-cyan-50 text-cyan-700 font-semibold' 
  : 'text-slate-600 hover:bg-slate-100';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | IDP Hijuelas - Admin</title>
  </head>
  <body class="flex min-h-screen bg-slate-50">
    <!-- Sidebar: Solo navegación -->
    <aside class="w-64 border-r border-slate-200 bg-white p-6 hidden md:flex flex-col">
      <div class="mb-10 font-bold text-xl text-cyan-600">IDP ADMIN</div>
      <nav class="space-y-1">
        {navItems.map(item => (
          <a href={item.href} class={`block px-4 py-2.5 rounded-xl transition-colors ${isActive(item.href)}`}>
            {item.label}
          </a>
        ))}
      </nav>
    </aside>

    <main class="flex-1">
      <!-- Header móvil -->
      <header class="md:hidden h-16 bg-white border-b border-slate-200 px-6 flex items-center font-bold text-cyan-600">
        IDP ADMIN
      </header>
      <div class="p-8">
        <slot />
      </div>
    </main>
  </body>
</html>