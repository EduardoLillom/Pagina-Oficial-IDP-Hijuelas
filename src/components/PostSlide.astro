---
interface Props {
  post: {
    type: string;
    title: string;
    summary: string;
    target_url?: string;
  };
}

const { post } = Astro.props;
const isQuote = post.type === 'cita';
const isEvent = post.type === 'evento';
---

<div class="slide-content h-64 flex flex-col justify-center items-center text-center transition-opacity duration-300">
  <div class="max-w-xl px-6">
    
    {isQuote ? (
      /* DISEÑO EDITORIAL: Frase completa en una línea */
      <div class="relative">
        <p class="text-2xl md:text-3xl font-serif text-slate-800 italic leading-relaxed">
          {post.title}
        </p>
      </div>
    ) : (
      /* DISEÑO ESTÁNDAR: Noticia, Aviso, Evento */
      <div class="space-y-4">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-cyan-600 bg-cyan-50 px-3 py-1 rounded-full">
          {post.type}
        </span>
        <h3 class="text-2xl font-extrabold text-slate-900 leading-tight">
          {post.title}
        </h3>
        <p class="text-slate-600 line-clamp-2">
          {post.summary}
        </p>
        {isEvent && (
          <a href="/eventos" class="inline-block text-sm font-bold text-cyan-600 border-b border-cyan-600 hover:text-cyan-800 transition">
            Ver detalles →
          </a>
        )}
      </div>
    )}
  </div>
</div>