---
// src/components/Navbar.astro
export const prerender = true;
const pathname = Astro.url.pathname;
const navItems = [
  { to: '/', label: 'Inicio' },
  { 
    label: 'Sobre Nosotros', 
    dropdown: [
      { title: 'Conócenos', links: [{ to: '/quienes-somos', label: 'Quiénes somos' }, { to: '/doctrina', label: 'Doctrina' }] },
    ] 
  },
  { to: '/horarios', label: 'Horarios'},
  { to: '/eventos', label: 'Eventos' },
  { to: '/nuestro-templo', label: 'Nuestro Templo' },
  { to: '/contacto', label: 'Contacto' },
];
---

<header class="fixed top-4 left-0 right-0 z-50 px-2 sm:px-4">
  <div class="mx-auto flex max-w-5xl items-center justify-between rounded-full border border-slate-200/50 bg-white/80 px-4 py-3 shadow-lg backdrop-blur-xl">
    
    <a href="/" class="flex items-center gap-2 pl-2 shrink-0">
      <img src="/logo.webp" alt="Logo IDP Hijuelas" class="h-9 w-9 shrink-0 sm:h-10 sm:w-10 object-contain" />
      <div class="flex flex-col min-w-0">
        <p class="text-xs font-semibold text-slate-900 truncate">IDP Hijuelas</p>
        <p class="text-[10px] uppercase tracking-[0.2em] text-slate-500 truncate">Fe, unidad y santidad</p>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-700">
      {navItems.map((item) => (
        item.dropdown ? (
          <div class="relative group" tabindex="0">
            <button class="flex items-center gap-1 hover:text-cyan-600 transition-colors" aria-haspopup="true" aria-expanded="false">
              {item.label}
              <span class="text-[8px] opacity-50 group-hover:rotate-180 transition-transform">▼</span>
            </button>
            <div class="absolute left-1/2 -translate-x-1/2 top-[calc(100%+12px)] w-max min-w-45 rounded-2xl bg-slate-900 p-4 text-white shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 z-50">
              {item.dropdown.map((col) => (
                <ul class="flex flex-col gap-2">
                  {col.links.map((link) => (
                    <li><a href={link.to} class="text-sm text-slate-300 hover:text-white px-2 py-1 block">{link.label}</a></li>
                  ))}
                </ul>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.to} class={`transition-colors ${pathname === item.to ? 'text-cyan-600' : 'hover:text-cyan-600'}`}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <button id="menu-toggle" class="md:hidden p-2 rounded-full hover:bg-slate-100 transition-colors" aria-label="Abrir menú">
      <span id="menu-icon" class="text-xl">≡</span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-2 right-2 mt-2 rounded-3xl border border-slate-200/50 bg-white/95 p-6 shadow-xl backdrop-blur-xl md:hidden transition-all duration-300">
    <nav class="flex flex-col gap-4">
      {navItems.map((item) => (
        item.dropdown ? (
          <div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">{item.label}</p>
            {item.dropdown.flatMap(col => col.links).map(link => (
              <a href={link.to} class="block py-2 text-slate-700 pl-4 border-l border-slate-200 hover:border-cyan-500 hover:text-cyan-600">{link.label}</a>
            ))}
          </div>
        ) : (
          <a href={item.to} class="py-2 text-lg font-medium text-slate-800">{item.label}</a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  function setupMenu() {
    const toggleBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    toggleBtn?.addEventListener('click', () => {
      const isHidden = mobileMenu?.classList.toggle('hidden');
      if (menuIcon) menuIcon.textContent = isHidden ? '≡' : '×';
    });

    // Cerrar menú al hacer clic en un enlace
    document.querySelectorAll('#mobile-menu a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        if (menuIcon) menuIcon.textContent = '≡';
      });
    });
  }
  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>