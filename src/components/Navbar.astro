---
// src/components/Navbar.astro
const pathname = Astro.url.pathname;
const navItems = [
  { to: '/', label: 'Inicio' },
  { to: '/nosotros', label: 'Nosotros' },
  { to: '/contacto', label: 'Contacto' },
];
---

<header class="fixed top-4 left-0 right-0 z-50 px-2 sm:px-4">
  <div class="mx-auto flex max-w-5xl items-center justify-between rounded-full border border-slate-200/50 bg-white/80 px-4 py-3 shadow-lg backdrop-blur-xl">
    
    <a href="/" class="flex items-center gap-2 pl-2 shrink-0">
    <div class="h-9 w-9 shrink-0 sm:h-10 sm:w-10">
        <img src="/logo.webp" alt="Logo IDP Hijuelas" class="h-full w-full object-contain" />
    </div>
    
    <div class="flex flex-col min-w-0">
        <p class="text-xs font-semibold text-slate-900 truncate sm:text-sm">
            IDP Hijuelas
        </p>
        <p class="hidden sm:block text-[10px] uppercase tracking-[0.15em] text-slate-500 truncate">
            Fe, unidad y santidad
        </p>
    </div>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-lg font-medium text-slate-700">
      {navItems.map((item) => {
        const isActive = pathname === item.to;
        return (
          <a href={item.to} class={`transition-colors ${isActive ? 'text-cyan-600 font-semibold' : 'hover:text-cyan-600'}`}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/contacto" class="hidden md:inline-flex rounded-full bg-slate-900 px-5 py-2 text-xs font-semibold text-white transition hover:bg-slate-700">
        Contáctanos
      </a>

      <button id="menu-toggle" class="md:hidden flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200 transition">
        <span id="menu-icon">≡</span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-2 right-2 mt-2 rounded-3xl border border-slate-200/50 bg-white/95 p-4 shadow-xl backdrop-blur-xl md:hidden">
    <nav class="flex flex-col gap-2">
      {navItems.map((item) => (
        <a href={item.to} class="px-4 py-3 rounded-xl hover:bg-slate-100 transition font-medium text-slate-700">
          {item.label}
        </a>
      ))}
      <a href="/contacto" class="mt-2 block w-full rounded-full bg-cyan-600 py-3 text-center text-sm font-semibold text-white">
        Contáctanos
      </a>
    </nav>
  </div>
</header>

<script>
  function setupMenu() {
    const toggleBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    toggleBtn?.addEventListener('click', () => {
      const isHidden = mobileMenu?.classList.toggle('hidden');
      if (menuIcon) menuIcon.textContent = isHidden ? '≡' : '×';
    });
  }
  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>