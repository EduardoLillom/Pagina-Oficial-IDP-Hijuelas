---
const { leader, priority = "normal" } = Astro.props;
---

<div class="group bg-white rounded-3xl border border-slate-100 shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col h-full w-full min-w-0">  
  <!-- Imagen optimizada -->
  <div class="aspect-[4/3] overflow-hidden bg-slate-100">
    <img 
      src={leader.image} 
      alt={leader.name}
      loading={priority === "high" ? "eager" : "lazy"}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  
  <div class="p-7 flex-1 flex flex-col">
    <span class="text-xs uppercase tracking-[0.5px] text-cyan-600 font-bold mb-2">
      {leader.role}
    </span>
    <h3 class="text-2xl font-bold text-slate-900 mb-4">{leader.name}</h3>
    <p class="text-slate-600 leading-relaxed text-[15.2px] flex-1">
      {leader.description}
    </p>
  </div>
</div>